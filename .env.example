# =============================================================
# AI-Powered Smart Inventory Management System — env template
# Copy to .env and fill in secrets before running docker-compose
# =============================================================

# ---- Spring Boot Backend ----
DB_URL=jdbc:postgresql://postgres:5432/inventory
DB_USERNAME=inventory_app
DB_PASSWORD=changeme_db_password

JWT_SECRET=changeme_jwt_secret_minimum_256_bits_long_placeholder_value
JWT_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_TIMEOUT_MS=2000

# ---- FastAPI AI Service ----
DATABASE_URL=postgresql://readonly_user:changeme_readonly_pw@postgres:5432/inventory
OPENROUTER_API_KEY=sk-or-changeme
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL_PATH=/app/models/anomaly_model.pkl

# ---- PostgreSQL (used by docker-compose) ----
POSTGRES_DB=inventory
POSTGRES_USER=inventory_app
POSTGRES_PASSWORD=changeme_db_password
